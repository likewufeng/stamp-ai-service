# =========================
# Stamp AI Service - env
# Copy to .env and edit
# =========================

# ---- Host port (uncommon default to avoid 80/8000 clashes) ----
HOST_PORT=18080

# ---- App (inside container; usually keep 8000) ----
APP_PORT=8000
UVICORN_WORKERS=2

# Upload limits
MAX_UPLOAD_BYTES=31457280
MAX_IMAGE_PIXELS=60000000

# File cleanup (uploads/outputs/temp)
CLEANUP_ENABLED=true
CLEANUP_INTERVAL_SECONDS=3600
CLEANUP_MAX_AGE_SECONDS=86400

# Logs
LOG_RETENTION_DAYS=3

# Resource limits (compose deploy.resources)
CPU_LIMIT=2.0
MEM_LIMIT=4G

# ---- Build mirrors (China-friendly defaults in compose) ----
APT_MIRROR=mirrors.aliyun.com
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
